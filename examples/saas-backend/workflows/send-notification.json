{
  "edges": [
    {
      "from": "load_workspace",
      "to": "build_email"
    },
    {
      "from": "build_email",
      "to": "send"
    }
  ],
  "id": "send-notification",
  "name": "Send Notification Email",
  "nodes": {
    "build_email": {
      "config": {
        "fields": {
          "body": "You have been invited to join the workspace '{{ nodes.load_workspace.name }}' as a {{ input.role }}. Log in to accept your invitation.",
          "subject": "You've been invited to {{ nodes.load_workspace.name }}",
          "to": "{{ input.email }}"
        }
      },
      "type": "transform.set"
    },
    "load_workspace": {
      "config": {
        "table": "workspaces",
        "where": { "id": "{{ input.workspace_id }}" }
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.findOne"
    },
    "send": {
      "config": {
        "body": "{{ nodes.build_email.body }}",
        "fields": {},
        "subject": "{{ nodes.build_email.subject }}",
        "to": "{{ nodes.build_email.to }}"
      },
      "services": {
        "mailer": "mailer"
      },
      "type": "email.send"
    }
  }
}
