{
  "id": "send-notification",
  "name": "Send Notification Email",
  "nodes": {
    "load_workspace": {
      "type": "db.query",
      "services": { "database": "main-db" },
      "config": {
        "query": "SELECT * FROM workspaces WHERE id = $1",
        "params": ["{{ input.workspace_id }}"]
      }
    },
    "build_email": {
      "type": "transform.set",
      "config": {
        "fields": {
          "to": "{{ input.email }}",
          "subject": "You've been invited to {{ nodes.load_workspace[0].name }}",
          "body": "You have been invited to join the workspace '{{ nodes.load_workspace[0].name }}' as a {{ input.role }}. Log in to accept your invitation."
        }
      }
    },
    "send": {
      "type": "email.send",
      "services": { "mailer": "mailer" },
      "config": {
        "to": "{{ nodes.build_email.to }}",
        "subject": "{{ nodes.build_email.subject }}",
        "body": "{{ nodes.build_email.body }}"
      }
    }
  },
  "edges": [
    { "from": "load_workspace", "to": "build_email" },
    { "from": "build_email", "to": "send" }
  ]
}
