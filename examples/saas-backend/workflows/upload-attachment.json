{
  "edges": [
    {
      "from": "upload",
      "to": "gen_id"
    },
    {
      "from": "gen_id",
      "to": "insert"
    },
    {
      "from": "insert",
      "to": "emit"
    },
    {
      "from": "emit",
      "to": "respond"
    }
  ],
  "id": "upload-attachment",
  "name": "Upload Attachment",
  "nodes": {
    "emit": {
      "config": {
        "data": {},
        "mode": "stream",
        "payload": {
          "attachment_id": "{{ nodes.gen_id.attachment_id }}",
          "content_type": "{{ nodes.upload.content_type }}",
          "path": "{{ nodes.upload.path }}",
          "workspace_id": "{{ input.workspace_id }}"
        },
        "topic": "attachment.uploaded"
      },
      "services": {
        "stream": "main-stream"
      },
      "type": "event.emit"
    },
    "gen_id": {
      "config": {
        "allowed_types": [],
        "fields": {
          "attachment_id": "{{ $uuid() }}"
        }
      },
      "type": "transform.set"
    },
    "insert": {
      "config": {
        "data": {
          "content_type": "{{ nodes.upload.content_type }}",
          "filename": "{{ nodes.upload.filename }}",
          "id": "{{ nodes.gen_id.attachment_id }}",
          "path": "{{ nodes.upload.path }}",
          "project_id": "{{ input.project_id }}",
          "size": "{{ nodes.upload.size }}",
          "uploaded_by": "{{ input.uploaded_by }}",
          "workspace_id": "{{ input.workspace_id }}"
        },
        "fields": {},
        "table": "attachments"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.create"
    },
    "respond": {
      "config": {
        "body": "{{ nodes.insert }}",
        "data": {},
        "status": 201
      },
      "type": "response.json"
    },
    "upload": {
      "config": {
        "allowed_types": [
          "image/jpeg",
          "image/png",
          "image/gif",
          "image/webp",
          "application/pdf"
        ],
        "data": {},
        "field": "file",
        "max_size": 10485760
      },
      "services": {
        "destination": "uploads"
      },
      "type": "upload.handle"
    }
  }
}
