{
  "edges": [
    {
      "from": "lookup",
      "to": "check"
    },
    {
      "from": "check",
      "output": "then",
      "to": "update"
    },
    {
      "from": "check",
      "output": "else",
      "to": "notfound"
    },
    {
      "from": "update",
      "to": "refetch"
    },
    {
      "from": "refetch",
      "to": "respond"
    }
  ],
  "id": "update-task",
  "name": "Update Task",
  "nodes": {
    "check": {
      "config": {
        "condition": "{{ len(nodes.lookup) \u003e 0 }}"
      },
      "type": "control.if"
    },
    "lookup": {
      "config": {
        "params": [
          "{{ input.task_id }}",
          "{{ input.workspace_id }}"
        ],
        "query": "SELECT * FROM tasks WHERE id = $1 AND workspace_id = $2"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.query"
    },
    "notfound": {
      "config": {
        "message": "Task not found",
        "status": 404
      },
      "type": "response.error"
    },
    "refetch": {
      "config": {
        "params": [
          "{{ input.task_id }}"
        ],
        "query": "SELECT * FROM tasks WHERE id = $1"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.query"
    },
    "respond": {
      "config": {
        "body": "{{ nodes.refetch[0] }}",
        "status": 200
      },
      "type": "response.json"
    },
    "update": {
      "config": {
        "params": [
          "{{ input.title }}",
          "{{ input.description }}",
          "{{ input.status }}",
          "{{ input.assignee_id }}",
          "{{ input.task_id }}",
          "{{ input.workspace_id }}"
        ],
        "query": "UPDATE tasks SET title = COALESCE($1, title), description = COALESCE($2, description), status = COALESCE($3, status), assignee_id = COALESCE($4, assignee_id) WHERE id = $5 AND workspace_id = $6"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.exec"
    }
  }
}
