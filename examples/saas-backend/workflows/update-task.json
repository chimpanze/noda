{
  "edges": [
    {
      "from": "lookup",
      "to": "update"
    },
    {
      "from": "update",
      "to": "refetch"
    },
    {
      "from": "refetch",
      "to": "respond"
    }
  ],
  "id": "update-task",
  "name": "Update Task",
  "nodes": {
    "lookup": {
      "config": {
        "table": "tasks",
        "where": {
          "id": "{{ input.task_id }}",
          "workspace_id": "{{ input.workspace_id }}"
        }
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.findOne"
    },
    "refetch": {
      "config": {
        "table": "tasks",
        "where": { "id": "{{ input.task_id }}" }
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.findOne"
    },
    "respond": {
      "config": {
        "body": "{{ nodes.refetch }}",
        "status": 200
      },
      "type": "response.json"
    },
    "update": {
      "config": {
        "params": [
          "{{ input.title }}",
          "{{ input.description }}",
          "{{ input.status }}",
          "{{ input.assignee_id }}",
          "{{ input.task_id }}",
          "{{ input.workspace_id }}"
        ],
        "query": "UPDATE tasks SET title = COALESCE($1, title), description = COALESCE($2, description), status = COALESCE($3, status), assignee_id = COALESCE($4, assignee_id) WHERE id = $5 AND workspace_id = $6"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.exec"
    }
  }
}
