{
  "edges": [
    {
      "from": "validate",
      "to": "gen_id"
    },
    {
      "from": "gen_id",
      "to": "insert"
    },
    {
      "from": "insert",
      "to": "emit"
    },
    {
      "from": "emit",
      "to": "respond"
    }
  ],
  "id": "invite-member",
  "name": "Invite Member",
  "nodes": {
    "emit": {
      "config": {
        "mode": "stream",
        "payload": {
          "email": "{{ input.email }}",
          "invited_by": "{{ input.invited_by }}",
          "role": "{{ input.role }}",
          "workspace_id": "{{ input.workspace_id }}"
        },
        "topic": "member.invited"
      },
      "services": {
        "stream": "main-stream"
      },
      "type": "event.emit"
    },
    "gen_id": {
      "config": {
        "fields": {
          "member_id": "{{ $uuid() }}"
        }
      },
      "type": "transform.set"
    },
    "insert": {
      "config": {
        "data": {
          "email": "{{ input.email }}",
          "id": "{{ nodes.gen_id.member_id }}",
          "role": "{{ input.role }}",
          "user_id": "{{ input.email }}",
          "workspace_id": "{{ input.workspace_id }}"
        },
        "table": "workspace_members"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.create"
    },
    "respond": {
      "config": {
        "body": "{{ nodes.insert }}",
        "status": 201
      },
      "type": "response.json"
    },
    "validate": {
      "config": {
        "data": "{{ input }}",
        "schema": {
          "$ref": "schemas/InviteMember"
        }
      },
      "type": "transform.validate"
    }
  }
}
