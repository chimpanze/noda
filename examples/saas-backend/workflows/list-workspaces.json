{
  "edges": [
    {
      "from": "rows",
      "to": "respond"
    }
  ],
  "id": "list-workspaces",
  "name": "List Workspaces",
  "nodes": {
    "respond": {
      "config": {
        "body": {
          "data": "{{ nodes.rows }}"
        },
        "headers": {},
        "status": 200
      },
      "type": "response.json"
    },
    "rows": {
      "config": {
        "joins": [
          {
            "on": "workspaces.id = workspace_members.workspace_id",
            "table": "workspace_members",
            "type": "INNER"
          }
        ],
        "order": "workspaces.created_at DESC",
        "select": [
          "workspaces.*"
        ],
        "table": "workspaces",
        "where_clause": {
          "params": [
            "{{ input.user_id }}"
          ],
          "query": "workspace_members.user_id = ?"
        }
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.find"
    }
  }
}
