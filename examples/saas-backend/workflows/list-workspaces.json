{
  "edges": [
    {
      "from": "rows",
      "to": "respond"
    }
  ],
  "id": "list-workspaces",
  "name": "List Workspaces",
  "nodes": {
    "respond": {
      "config": {
        "body": {
          "data": "{{ nodes.rows }}"
        },
        "status": 200
      },
      "type": "response.json"
    },
    "rows": {
      "config": {
        "table": "workspaces",
        "select": ["workspaces.*"],
        "joins": [
          {
            "type": "INNER",
            "table": "workspace_members",
            "on": "workspaces.id = workspace_members.workspace_id"
          }
        ],
        "where_clause": {
          "query": "workspace_members.user_id = ?",
          "params": ["{{ input.user_id }}"]
        },
        "order": "workspaces.created_at DESC"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.find"
    }
  }
}
