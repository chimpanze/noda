{
  "id": "create-task",
  "name": "Create Task",
  "nodes": {
    "validate": {
      "type": "transform.validate",
      "config": {
        "data": "{{ input }}",
        "schema": { "$ref": "schemas/CreateTask" }
      }
    },
    "gen_id": {
      "type": "transform.set",
      "config": {
        "fields": {
          "task_id": "{{ $uuid() }}"
        }
      }
    },
    "insert": {
      "type": "db.create",
      "services": { "database": "main-db" },
      "config": {
        "table": "tasks",
        "data": {
          "id": "{{ nodes.gen_id.task_id }}",
          "workspace_id": "{{ input.workspace_id }}",
          "project_id": "{{ input.project_id }}",
          "title": "{{ input.title }}",
          "description": "{{ input.description }}",
          "assignee_id": "{{ input.assignee_id }}",
          "status": "todo"
        }
      }
    },
    "check_assignee": {
      "type": "control.if",
      "config": {
        "condition": "{{ input.assignee_id != nil && input.assignee_id != '' }}"
      }
    },
    "emit_assigned": {
      "type": "event.emit",
      "services": { "stream": "main-stream" },
      "config": {
        "mode": "stream",
        "topic": "task.assigned",
        "payload": {
          "task_id": "{{ nodes.gen_id.task_id }}",
          "workspace_id": "{{ input.workspace_id }}",
          "assignee_id": "{{ input.assignee_id }}",
          "title": "{{ input.title }}"
        }
      }
    },
    "respond_with_event": {
      "type": "response.json",
      "config": {
        "status": 201,
        "body": "{{ nodes.insert }}"
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 201,
        "body": "{{ nodes.insert }}"
      }
    }
  },
  "edges": [
    { "from": "validate", "to": "gen_id" },
    { "from": "gen_id", "to": "insert" },
    { "from": "insert", "to": "check_assignee" },
    { "from": "check_assignee", "output": "then", "to": "emit_assigned" },
    { "from": "check_assignee", "output": "else", "to": "respond" },
    { "from": "emit_assigned", "to": "respond_with_event" }
  ]
}
