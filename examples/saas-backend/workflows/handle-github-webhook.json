{
  "edges": [
    {
      "from": "switch_event",
      "output": "issues",
      "to": "emit_issue"
    },
    {
      "from": "switch_event",
      "output": "pull_request",
      "to": "emit_pr"
    },
    {
      "from": "switch_event",
      "output": "default",
      "to": "log_unknown"
    },
    {
      "from": "emit_issue",
      "to": "respond"
    },
    {
      "from": "emit_pr",
      "to": "respond"
    },
    {
      "from": "log_unknown",
      "to": "respond"
    }
  ],
  "id": "handle-github-webhook",
  "name": "Handle GitHub Webhook",
  "nodes": {
    "emit_issue": {
      "config": {
        "mode": "stream",
        "payload": "{{ input.payload }}",
        "topic": "github.issue"
      },
      "services": {
        "stream": "main-stream"
      },
      "type": "event.emit"
    },
    "emit_pr": {
      "config": {
        "mode": "stream",
        "payload": "{{ input.payload }}",
        "topic": "github.pr"
      },
      "services": {
        "stream": "main-stream"
      },
      "type": "event.emit"
    },
    "log_unknown": {
      "config": {
        "level": "info",
        "message": "Ignoring unknown GitHub event: {{ input.event_type }}"
      },
      "type": "util.log"
    },
    "respond": {
      "config": {
        "body": {
          "status": "ok"
        },
        "status": 200
      },
      "type": "response.json"
    },
    "switch_event": {
      "config": {
        "cases": [
          "issues",
          "pull_request"
        ],
        "expression": "{{ input.event_type }}"
      },
      "type": "control.switch"
    }
  }
}
