{
  "id": "handle-github-webhook",
  "name": "Handle GitHub Webhook",
  "nodes": {
    "switch_event": {
      "type": "control.switch",
      "config": {
        "expression": "{{ input.event_type }}",
        "cases": ["issues", "pull_request"]
      }
    },
    "emit_issue": {
      "type": "event.emit",
      "services": { "stream": "main-stream" },
      "config": {
        "mode": "stream",
        "topic": "github.issue",
        "payload": "{{ input.payload }}"
      }
    },
    "emit_pr": {
      "type": "event.emit",
      "services": { "stream": "main-stream" },
      "config": {
        "mode": "stream",
        "topic": "github.pr",
        "payload": "{{ input.payload }}"
      }
    },
    "log_unknown": {
      "type": "util.log",
      "config": {
        "level": "info",
        "message": "Ignoring unknown GitHub event: {{ input.event_type }}"
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": { "status": "ok" }
      }
    }
  },
  "edges": [
    { "from": "switch_event", "output": "issues", "to": "emit_issue" },
    { "from": "switch_event", "output": "pull_request", "to": "emit_pr" },
    { "from": "switch_event", "output": "default", "to": "log_unknown" },
    { "from": "emit_issue", "to": "respond" },
    { "from": "emit_pr", "to": "respond" },
    { "from": "log_unknown", "to": "respond" }
  ]
}
