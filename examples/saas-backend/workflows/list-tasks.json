{
  "edges": [
    {
      "from": "total",
      "to": "respond"
    },
    {
      "from": "rows",
      "to": "respond"
    }
  ],
  "id": "list-tasks",
  "name": "List Tasks",
  "nodes": {
    "respond": {
      "config": {
        "body": {
          "data": "{{ nodes.rows }}",
          "pagination": {
            "limit": "{{ input.limit }}",
            "page": "{{ input.page }}",
            "total": "{{ nodes.total.count }}"
          }
        },
        "status": 200
      },
      "type": "response.json"
    },
    "rows": {
      "config": {
        "table": "tasks",
        "where": { "workspace_id": "{{ input.workspace_id }}" },
        "order": "created_at DESC",
        "limit": "{{ input.limit }}",
        "offset": "{{ (toInt(input.page) - 1) * toInt(input.limit) }}"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.find"
    },
    "total": {
      "config": {
        "table": "tasks",
        "where": { "workspace_id": "{{ input.workspace_id }}" }
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.count"
    }
  }
}
