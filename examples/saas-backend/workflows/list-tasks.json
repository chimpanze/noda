{
  "edges": [
    {
      "from": "total",
      "to": "respond"
    },
    {
      "from": "rows",
      "to": "respond"
    }
  ],
  "id": "list-tasks",
  "name": "List Tasks",
  "nodes": {
    "respond": {
      "config": {
        "body": {
          "data": "{{ nodes.rows }}",
          "pagination": {
            "limit": "{{ input.limit }}",
            "page": "{{ input.page }}",
            "total": "{{ nodes.total[0].cnt }}"
          }
        },
        "status": 200
      },
      "type": "response.json"
    },
    "rows": {
      "config": {
        "params": [
          "{{ input.workspace_id }}",
          "{{ input.limit }}",
          "{{ (toInt(input.page) - 1) * toInt(input.limit) }}"
        ],
        "query": "SELECT * FROM tasks WHERE workspace_id = $1 ORDER BY created_at DESC LIMIT $2 OFFSET $3"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.query"
    },
    "total": {
      "config": {
        "params": [
          "{{ input.workspace_id }}"
        ],
        "query": "SELECT COUNT(*) as cnt FROM tasks WHERE workspace_id = $1"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.query"
    }
  }
}
