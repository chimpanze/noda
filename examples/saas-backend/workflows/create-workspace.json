{
  "edges": [
    {
      "from": "validate",
      "to": "gen_id"
    },
    {
      "from": "gen_id",
      "to": "insert_workspace"
    },
    {
      "from": "insert_workspace",
      "to": "insert_member"
    },
    {
      "from": "insert_member",
      "to": "respond"
    }
  ],
  "id": "create-workspace",
  "name": "Create Workspace",
  "nodes": {
    "gen_id": {
      "config": {
        "fields": {
          "workspace_id": "{{ $uuid() }}"
        },
        "schema": {}
      },
      "type": "transform.set"
    },
    "insert_member": {
      "config": {
        "data": {
          "email": "",
          "role": "owner",
          "user_id": "{{ input.owner_id }}",
          "workspace_id": "{{ nodes.gen_id.workspace_id }}"
        },
        "fields": {},
        "table": "workspace_members"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.create"
    },
    "insert_workspace": {
      "config": {
        "data": {
          "id": "{{ nodes.gen_id.workspace_id }}",
          "name": "{{ input.name }}",
          "owner_id": "{{ input.owner_id }}",
          "slug": "{{ input.slug }}"
        },
        "fields": {},
        "table": "workspaces"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.create"
    },
    "respond": {
      "config": {
        "body": "{{ nodes.insert_workspace }}",
        "data": {},
        "status": 201
      },
      "type": "response.json"
    },
    "validate": {
      "config": {
        "data": "{{ input }}",
        "schema": {
          "$ref": "schemas/CreateWorkspace"
        }
      },
      "type": "transform.validate"
    }
  }
}
