{
  "edges": [
    {
      "from": "switch_event",
      "output": "invoice.paid",
      "to": "lookup_workspace"
    },
    {
      "from": "switch_event",
      "output": "default",
      "to": "log_unknown"
    },
    {
      "from": "lookup_workspace",
      "to": "update_subscription"
    },
    {
      "from": "update_subscription",
      "to": "emit_payment"
    },
    {
      "from": "emit_payment",
      "to": "respond"
    },
    {
      "from": "log_unknown",
      "to": "respond"
    }
  ],
  "id": "handle-stripe-webhook",
  "name": "Handle Stripe Webhook",
  "nodes": {
    "emit_payment": {
      "config": {
        "mode": "stream",
        "payload": {
          "amount": "{{ input.payload.data.object.amount_paid }}",
          "customer_id": "{{ input.payload.data.object.customer }}"
        },
        "topic": "payment.received"
      },
      "services": {
        "stream": "main-stream"
      },
      "type": "event.emit"
    },
    "log_unknown": {
      "config": {
        "cases": [],
        "level": "info",
        "message": "Ignoring Stripe event: {{ input.event_type }}"
      },
      "type": "util.log"
    },
    "lookup_workspace": {
      "config": {
        "table": "workspaces",
        "where": { "stripe_customer_id": "{{ input.payload.data.object.customer }}" }
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.findOne"
    },
    "respond": {
      "config": {
        "body": {
          "status": "ok"
        },
        "status": 200
      },
      "type": "response.json"
    },
    "switch_event": {
      "config": {
        "cases": [
          "invoice.paid"
        ],
        "expression": "{{ input.event_type }}"
      },
      "type": "control.switch"
    },
    "update_subscription": {
      "config": {
        "table": "workspaces",
        "data": { "subscription_status": "active" },
        "where": { "stripe_customer_id": "{{ input.payload.data.object.customer }}" }
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.update"
    }
  }
}
