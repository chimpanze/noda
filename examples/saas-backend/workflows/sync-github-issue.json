{
  "edges": [
    {
      "from": "switch_action",
      "output": "opened",
      "to": "create_task"
    },
    {
      "from": "switch_action",
      "output": "closed",
      "to": "close_task"
    },
    {
      "from": "switch_action",
      "output": "default",
      "to": "log_unknown"
    }
  ],
  "id": "sync-github-issue",
  "name": "Sync GitHub Issue",
  "nodes": {
    "close_task": {
      "config": {
        "table": "tasks",
        "data": { "status": "done" },
        "where": { "github_issue_id": "{{ input.issue_id }}" }
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.update"
    },
    "create_task": {
      "config": {
        "data": {
          "description": "{{ input.body }}",
          "github_issue_id": "{{ input.issue_id }}",
          "project_id": "{{ input.project_id }}",
          "status": "todo",
          "title": "{{ input.title }}",
          "workspace_id": "{{ input.workspace_id }}"
        },
        "table": "tasks"
      },
      "services": {
        "database": "main-db"
      },
      "type": "db.create"
    },
    "log_unknown": {
      "config": {
        "level": "info",
        "message": "Ignoring GitHub issue action: {{ input.action }}"
      },
      "type": "util.log"
    },
    "switch_action": {
      "config": {
        "cases": [
          "opened",
          "closed"
        ],
        "expression": "{{ input.action }}"
      },
      "type": "control.switch"
    }
  }
}
