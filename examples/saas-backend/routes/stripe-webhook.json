{
  "id": "stripe-webhook",
  "method": "POST",
  "path": "/webhooks/stripe",
  "summary": "Handle Stripe webhook events",
  "tags": [
    "webhooks"
  ],
  "trigger": {
    "input": {
      "event_type": "{{ body.type }}",
      "payload": "{{ body }}",
      "signature": "{{ headers['Stripe-Signature'] }}"
    },
    "raw_body": true,
    "workflow": "handle-stripe-webhook"
  }
}
