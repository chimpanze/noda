{
  "id": "test-create-task",
  "tests": [
    {
      "expect": {
        "output": {
          "respond_with_event.status": 201
        },
        "status": "success"
      },
      "input": {
        "assignee_id": "user-2",
        "description": "Users cannot log in",
        "project_id": "proj-1",
        "title": "Fix login bug",
        "user_id": "user-1",
        "workspace_id": "ws-1"
      },
      "mocks": {
        "emit_assigned": {
          "output": {
            "status": "emitted"
          }
        },
        "insert": {
          "output": {
            "assignee_id": "user-2",
            "id": "task-1",
            "project_id": "proj-1",
            "status": "todo",
            "title": "Fix login bug",
            "workspace_id": "ws-1"
          }
        },
        "respond": {
          "output": {
            "status": 201
          }
        },
        "respond_with_event": {
          "output": {
            "status": 201
          }
        },
        "validate": {
          "output": {
            "project_id": "proj-1",
            "title": "Fix login bug"
          }
        }
      },
      "name": "creates task with assignee emits event"
    },
    {
      "expect": {
        "output": {
          "respond.status": 201
        },
        "status": "success"
      },
      "input": {
        "assignee_id": "",
        "description": "",
        "project_id": "proj-1",
        "title": "Write docs",
        "user_id": "user-1",
        "workspace_id": "ws-1"
      },
      "mocks": {
        "insert": {
          "output": {
            "id": "task-2",
            "project_id": "proj-1",
            "status": "todo",
            "title": "Write docs",
            "workspace_id": "ws-1"
          }
        },
        "respond": {
          "output": {
            "status": 201
          }
        },
        "respond_with_event": {
          "output": {
            "status": 201
          }
        },
        "validate": {
          "output": {
            "project_id": "proj-1",
            "title": "Write docs"
          }
        }
      },
      "name": "creates task without assignee skips event"
    }
  ],
  "workflow": "create-task"
}
