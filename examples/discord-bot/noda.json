{
  "wasm_runtimes": {
    "discord-bot": {
      "module": "wasm/bot.wasm",
      "tick_rate": 2,
      "encoding": "json",
      "config": {
        "token": "{{ $env('DISCORD_BOT_TOKEN') }}"
      },
      "allow_outbound": {
        "ws": ["gateway.discord.gg"],
        "http": ["discord.com"]
      }
    }
  }
}
