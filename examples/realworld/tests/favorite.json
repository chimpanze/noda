{
  "id": "favorite",
  "workflow": "favorite",
  "tests": [
    {
      "name": "favorites an existing article",
      "input": {
        "slug": "how-to-train-your-dragon",
        "user_id": "u1"
      },
      "mocks": {
        "find_article": {
          "output": [{ "id": "a1", "author_id": "u2" }]
        },
        "insert_favorite": {
          "output": { "rows_affected": 1 }
        },
        "article": {
          "output": [
            {
              "slug": "how-to-train-your-dragon",
              "title": "How to train your dragon",
              "description": "Ever wonder how?",
              "body": "It takes a Jacobian",
              "created_at": "2016-02-18T03:22:56.637Z",
              "updated_at": "2016-02-18T03:48:35.824Z",
              "author_id": "u2",
              "tag_list": ["dragons", "training"],
              "favorites_count": 1,
              "favorited": true
            }
          ]
        },
        "author": {
          "output": [
            {
              "username": "jake",
              "bio": "",
              "image": "",
              "following": false
            }
          ]
        }
      },
      "expect": {
        "status": "success",
        "output": {
          "respond.status": 200
        }
      }
    },
    {
      "name": "404s for an unknown slug",
      "input": {
        "slug": "nope",
        "user_id": "u1"
      },
      "mocks": {
        "find_article": {
          "output": []
        }
      },
      "expect": {
        "status": "success",
        "output": {
          "respond_not_found.status": 404
        }
      }
    }
  ]
}
