{
  "id": "update-user",
  "workflow": "update-user",
  "tests": [
    {
      "name": "updates profile fields without changing password",
      "input": {
        "user_id": "u1",
        "email": "user1@example.com",
        "username": "user1",
        "password": null,
        "bio": "bio",
        "image": "img",
        "user_raw": { "email": "user1@example.com", "username": "user1", "bio": "bio", "image": "img" }
      },
      "mocks": {
        "fetch": {
          "output": {
            "email": "old@example.com",
            "metadata": { "username": "olduser", "bio": "oldbio", "image": "oldimg" }
          }
        },
        "update": { "output": { "rows_affected": 1 } },
        "sign": { "output": "jwt-abc" }
      },
      "expect": {
        "status": "success",
        "output": { "respond.status": 200 }
      }
    },
    {
      "name": "updates password when provided",
      "input": {
        "user_id": "u1",
        "email": "user1@example.com",
        "username": "user1",
        "password": "newpassword",
        "bio": "bio",
        "image": "img",
        "user_raw": { "email": "user1@example.com", "username": "user1", "password": "newpassword", "bio": "bio", "image": "img" }
      },
      "mocks": {
        "fetch": {
          "output": {
            "email": "user1@example.com",
            "metadata": { "username": "user1", "bio": "bio", "image": "img" }
          }
        },
        "set_password": { "output": {} },
        "update": { "output": { "rows_affected": 1 } },
        "sign": { "output": "jwt-abc" }
      },
      "expect": {
        "status": "success",
        "output": { "respond.status": 200 }
      }
    },
    {
      "name": "duplicate email or username on update returns the standard envelope",
      "input": {
        "user_id": "u1",
        "email": "taken@example.com",
        "username": "user1",
        "password": null,
        "bio": "bio",
        "image": "img",
        "user_raw": { "email": "taken@example.com", "username": "user1", "bio": "bio", "image": "img" }
      },
      "mocks": {
        "fetch": {
          "output": {
            "email": "user1@example.com",
            "metadata": { "username": "user1", "bio": "bio", "image": "img" }
          }
        },
        "update": { "output_name": "exists", "output": {} }
      },
      "expect": {
        "status": "success",
        "output": {
          "respond_conflict.status": 422,
          "respond_conflict.body.errors.body": ["email or username has already been taken"]
        }
      }
    },
    {
      "name": "invalid email type fails validation",
      "input": {
        "user_id": "u1",
        "email": 123,
        "username": "user1",
        "password": null,
        "bio": "bio",
        "image": "img",
        "user_raw": { "email": 123, "username": "user1", "bio": "bio", "image": "img" }
      },
      "mocks": {
        "fetch": {
          "output": {
            "email": "user1@example.com",
            "metadata": { "username": "user1", "bio": "bio", "image": "img" }
          }
        },
        "update": { "output": { "rows_affected": 1 } },
        "sign": { "output": "jwt-abc" }
      },
      "expect": {
        "status": "success",
        "output": { "respond_invalid_input.status": 422 }
      }
    },
    {
      "name": "missing/invalid token yields 401",
      "input": {
        "user_id": "gone",
        "email": "user1@example.com",
        "username": "user1",
        "password": null,
        "bio": "bio",
        "image": "img",
        "user_raw": { "email": "user1@example.com", "username": "user1", "bio": "bio", "image": "img" }
      },
      "mocks": {
        "fetch": { "output_name": "not_found", "output": {} }
      },
      "expect": {
        "status": "success",
        "output": { "respond_missing.status": 401 }
      }
    },
    {
      "name": "explicit null email is rejected (omission would keep it, so null must not silently no-op)",
      "input": {
        "user_id": "u1",
        "user_raw": { "email": null }
      },
      "mocks": {
        "fetch": {
          "output": {
            "email": "user1@example.com",
            "metadata": { "username": "user1", "bio": "bio", "image": "img" }
          }
        }
      },
      "expect": {
        "status": "success",
        "output": {
          "respond_email_invalid.status": 422,
          "respond_email_invalid.body.errors.email": ["can't be blank"]
        }
      }
    },
    {
      "name": "explicit blank username is rejected",
      "input": {
        "user_id": "u1",
        "user_raw": { "username": "" }
      },
      "mocks": {
        "fetch": {
          "output": {
            "email": "user1@example.com",
            "metadata": { "username": "user1", "bio": "bio", "image": "img" }
          }
        }
      },
      "expect": {
        "status": "success",
        "output": {
          "respond_username_invalid.status": 422,
          "respond_username_invalid.body.errors.username": ["can't be blank"]
        }
      }
    },
    {
      "name": "password shorter than 8 characters is rejected",
      "input": {
        "user_id": "u1",
        "user_raw": { "password": "short7c" }
      },
      "mocks": {
        "fetch": {
          "output": {
            "email": "user1@example.com",
            "metadata": { "username": "user1", "bio": "bio", "image": "img" }
          }
        }
      },
      "expect": {
        "status": "success",
        "output": { "respond_password_invalid.status": 422 }
      }
    },
    {
      "name": "explicit null bio clears it rather than keeping the old value",
      "input": {
        "user_id": "u1",
        "user_raw": { "bio": null }
      },
      "mocks": {
        "fetch": {
          "output": {
            "email": "user1@example.com",
            "metadata": { "username": "user1", "bio": "was set before", "image": "img" }
          }
        },
        "update": { "output": { "rows_affected": 1 } },
        "sign": { "output": "jwt-abc" }
      },
      "expect": {
        "status": "success",
        "output": {
          "respond.status": 200,
          "respond.body.user.bio": null,
          "respond.body.user.username": "user1"
        }
      }
    }
  ]
}
