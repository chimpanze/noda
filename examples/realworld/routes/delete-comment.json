{
  "id": "delete-comment",
  "method": "DELETE",
  "path": "/api/articles/:slug/comments/:id",
  "middleware": ["auth.jwt"],
  "trigger": {
    "workflow": "delete-comment",
    "input": {
      "slug": "{{ params.slug }}",
      "id": "{{ params.id }}",
      "user_id": "{{ auth.sub }}"
    }
  }
}
