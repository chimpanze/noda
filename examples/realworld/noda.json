{
  "services": {
    "main-db": {
      "plugin": "db",
      "config": { "driver": "postgres", "url": "{{ $env('DATABASE_URL') }}" }
    },
    "auth": {
      "plugin": "auth",
      "config": { "database": "main-db" }
    }
  },
  "security": {
    "jwt": {
      "secret": "{{ $env('JWT_SECRET') }}",
      "algorithm": "HS256",
      "auth_scheme": "Token",
      "token_lookup": "header:Authorization"
    }
  },
  "middleware_presets": {
    "authenticated": ["auth.jwt"]
  }
}
