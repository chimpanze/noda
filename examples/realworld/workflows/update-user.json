{
  "id": "update-user",
  "name": "Update User",
  "description": "The `update` (`db.update`) node's `exists` output is wired to `respond_conflict`, mirroring register's duplicate-email envelope/status (422, 'email or username has already been taken'). `exists` fires only on a unique-constraint violation, so an unrelated database failure leaves the generic `error` output unwired and fails the request loudly as a 500 rather than mislabelling it a duplicate. `check_email_invalid`/`check_username_invalid`/`has_password`+`check_password_valid` read `input.user_raw` (the route maps the WHOLE `body.user` sub-object, not just individual fields) because Noda's trigger-input mapping flattens presence: `\"email\": \"{{ body.user.email }}\"` always creates the `input.email` key (as nil) whether the client sent `\"email\": null` or omitted the key — the conformance suite requires the former (explicit null/blank) to 422 while the latter (omitted, 'don't change this field') must succeed, and only the raw sub-object preserves that distinction (checked via expr's `'key' in map` membership test, which is presence-aware unlike a nil comparison on a flattened field).",
  "nodes": {
    "validate": {
      "type": "transform.validate",
      "config": { "data": "{{ input }}", "schema": { "$ref": "schemas/UpdateUser" } }
    },
    "respond_invalid_input": {
      "type": "response.json",
      "config": {
        "status": 422,
        "body": { "errors": { "body": ["{{ nodes.validate.error }}"] } }
      }
    },
    "fetch": {
      "type": "auth.get_user",
      "services": { "auth": "auth", "database": "main-db" },
      "config": { "user_id": "{{ input.user_id }}" }
    },
    "respond_missing": {
      "type": "response.json",
      "config": {
        "status": 401,
        "body": { "errors": { "body": ["invalid token"] } }
      }
    },
    "check_email_invalid": {
      "type": "control.if",
      "config": { "condition": "{{ 'email' in input.user_raw && (input.user_raw.email == nil || input.user_raw.email == '') }}" }
    },
    "respond_email_invalid": {
      "type": "response.json",
      "config": { "status": 422, "body": { "errors": { "email": ["can't be blank"] } } }
    },
    "check_username_invalid": {
      "type": "control.if",
      "config": { "condition": "{{ 'username' in input.user_raw && (input.user_raw.username == nil || input.user_raw.username == '') }}" }
    },
    "respond_username_invalid": {
      "type": "response.json",
      "config": { "status": 422, "body": { "errors": { "username": ["can't be blank"] } } }
    },
    "compute_metadata": {
      "type": "transform.set",
      "config": {
        "fields": {
          "username": "{{ ('username' in input.user_raw && input.user_raw.username != nil && input.user_raw.username != '') ? input.user_raw.username : nodes.fetch.metadata.username }}",
          "bio": "{{ 'bio' in input.user_raw ? (input.user_raw.bio == nil || input.user_raw.bio == '' ? nil : input.user_raw.bio) : nodes.fetch.metadata.bio }}",
          "image": "{{ 'image' in input.user_raw ? (input.user_raw.image == nil || input.user_raw.image == '' ? nil : input.user_raw.image) : nodes.fetch.metadata.image }}"
        }
      }
    },
    "has_password": {
      "type": "control.if",
      "config": { "condition": "{{ 'password' in input.user_raw }}" }
    },
    "check_password_valid": {
      "type": "control.if",
      "config": { "condition": "{{ input.user_raw.password != nil && input.user_raw.password != '' && len(input.user_raw.password) >= 8 }}" }
    },
    "respond_password_invalid": {
      "type": "response.json",
      "config": { "status": 422, "body": { "errors": { "password": ["is too short (minimum is 8 characters)"] } } }
    },
    "set_password": {
      "type": "auth.set_password",
      "services": { "auth": "auth", "database": "main-db" },
      "config": {
        "user_id": "{{ input.user_id }}",
        "password": "{{ input.password }}"
      }
    },
    "update": {
      "type": "db.update",
      "services": { "database": "main-db" },
      "config": {
        "table": "auth_users",
        "data": {
          "email": "{{ input.email ?? nodes.fetch.email }}",
          "metadata": "{{ nodes.compute_metadata }}",
          "updated_at": "{{ now() }}"
        },
        "where": { "id": "{{ input.user_id }}" }
      }
    },
    "respond_conflict": {
      "type": "response.json",
      "config": {
        "status": 422,
        "body": { "errors": { "body": ["email or username has already been taken"] } }
      }
    },
    "sign": {
      "type": "util.jwt_sign",
      "config": {
        "claims": {
          "sub": "{{ input.user_id }}",
          "username": "{{ nodes.compute_metadata.username }}"
        },
        "secret": "{{ secrets.JWT_SECRET }}",
        "expiry": "72h"
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": {
          "user": {
            "email": "{{ input.email ?? nodes.fetch.email }}",
            "username": "{{ nodes.compute_metadata.username }}",
            "bio": "{{ nodes.compute_metadata.bio }}",
            "image": "{{ nodes.compute_metadata.image }}",
            "token": "{{ nodes.sign }}"
          }
        }
      }
    }
  },
  "edges": [
    { "from": "validate", "to": "fetch" },
    { "from": "validate", "output": "error", "to": "respond_invalid_input" },
    { "from": "fetch", "to": "check_email_invalid" },
    { "from": "fetch", "output": "not_found", "to": "respond_missing" },
    { "from": "check_email_invalid", "output": "then", "to": "respond_email_invalid" },
    { "from": "check_email_invalid", "output": "else", "to": "check_username_invalid" },
    { "from": "check_username_invalid", "output": "then", "to": "respond_username_invalid" },
    { "from": "check_username_invalid", "output": "else", "to": "compute_metadata" },
    { "from": "compute_metadata", "to": "has_password" },
    { "from": "has_password", "output": "then", "to": "check_password_valid" },
    { "from": "has_password", "output": "else", "to": "update" },
    { "from": "check_password_valid", "output": "then", "to": "set_password" },
    { "from": "check_password_valid", "output": "else", "to": "respond_password_invalid" },
    { "from": "set_password", "to": "update" },
    { "from": "update", "to": "sign" },
    { "from": "update", "output": "exists", "to": "respond_conflict" },
    { "from": "sign", "to": "respond" }
  ]
}
