{
  "id": "find-one",
  "name": "Find One Book",
  "nodes": {
    "fetch": {
      "type": "db.findOne",
      "services": { "database": "main-db" },
      "config": {
        "table": "books",
        "where": { "id": "{{ input.id }}" }
      }
    },
    "respond": {
      "type": "response.json",
      "config": { "status": 200, "body": "{{ nodes.fetch }}" }
    },
    "not_found": {
      "type": "response.error",
      "config": { "status": 404, "code": "NOT_FOUND", "message": "Book not found" }
    }
  },
  "edges": [
    { "from": "fetch", "to": "respond" },
    { "from": "fetch", "output": "error", "to": "not_found" }
  ]
}
