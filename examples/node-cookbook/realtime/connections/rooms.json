{
  "sync": { "pubsub": "realtime" },
  "endpoints": {
    "rooms": {
      "type": "websocket",
      "path": "/ws/rooms/:room",
      "channels": { "pattern": "room.{{ request.params.room }}" },
      "on_connect": "room-joined"
    },
    "feed": {
      "type": "sse",
      "path": "/events/:channel",
      "channels": { "pattern": "feed.{{ request.params.channel }}" },
      "heartbeat": "1s"
    }
  }
}
