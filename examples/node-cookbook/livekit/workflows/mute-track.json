{
  "id": "mute-track",
  "name": "Mute Track",
  "nodes": {
    "mute": {
      "type": "lk.mute_track",
      "services": { "livekit": "lk" },
      "config": {
        "room": "{{ input.room }}",
        "identity": "{{ input.identity }}",
        "track_sid": "{{ input.track_sid }}",
        "muted": "{{ input.muted }}"
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": "{{ nodes.mute }}"
      }
    },
    "not_found": {
      "type": "response.error",
      "config": {
        "status": 404,
        "code": "NO_SUCH_PARTICIPANT",
        "message": "Participant not found in room"
      }
    }
  },
  "edges": [
    { "from": "mute", "to": "respond" },
    { "from": "mute", "output": "error", "to": "not_found" }
  ]
}
