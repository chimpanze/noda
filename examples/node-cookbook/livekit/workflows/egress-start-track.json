{
  "id": "egress-start-track",
  "name": "Start Track Egress",
  "nodes": {
    "start": {
      "type": "lk.egressStartTrack",
      "services": { "livekit": "lk" },
      "config": {
        "room": "{{ input.room }}",
        "track_sid": "{{ input.track_sid }}",
        "output": {
          "type": "file",
          "filepath": "/out/recording.mp4"
        }
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": "{{ nodes.start }}"
      }
    },
    "unavailable": {
      "type": "response.error",
      "config": {
        "status": 502,
        "code": "EGRESS_UNAVAILABLE",
        "message": "Track egress could not be started"
      }
    }
  },
  "edges": [
    { "from": "start", "to": "respond" },
    { "from": "start", "output": "error", "to": "unavailable" }
  ]
}
