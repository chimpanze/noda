{
  "id": "participant-update",
  "name": "Update Participant",
  "nodes": {
    "update": {
      "type": "lk.participantUpdate",
      "services": { "livekit": "lk" },
      "config": {
        "room": "{{ input.room }}",
        "identity": "{{ input.identity }}",
        "metadata": "{{ input.metadata }}"
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": "{{ nodes.update }}"
      }
    },
    "not_found": {
      "type": "response.error",
      "config": {
        "status": 404,
        "code": "NO_SUCH_PARTICIPANT",
        "message": "Participant not found in room"
      }
    }
  },
  "edges": [
    { "from": "update", "to": "respond" },
    { "from": "update", "output": "error", "to": "not_found" }
  ]
}
