{
  "id": "token",
  "name": "Issue Access Token",
  "nodes": {
    "issue": {
      "type": "lk.token",
      "services": { "livekit": "lk" },
      "config": {
        "identity": "{{ input.identity }}",
        "room": "{{ input.room }}",
        "name": "{{ input.name }}",
        "grants": {
          "roomJoin": true,
          "canPublish": true,
          "canSubscribe": true
        }
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": "{{ nodes.issue }}"
      }
    }
  },
  "edges": [
    { "from": "issue", "to": "respond" }
  ]
}
