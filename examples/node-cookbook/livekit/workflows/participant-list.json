{
  "id": "participant-list",
  "name": "List Participants",
  "nodes": {
    "list": {
      "type": "lk.participantList",
      "services": { "livekit": "lk" },
      "config": {
        "room": "{{ input.room }}"
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": { "participants": "{{ nodes.list.participants }}" }
      }
    }
  },
  "edges": [
    { "from": "list", "to": "respond" }
  ]
}
