{
  "id": "send-data",
  "method": "POST",
  "path": "/api/rooms/:room/data",
  "summary": "lk.send_data — broadcast a data message into a room",
  "tags": ["livekit"],
  "trigger": {
    "workflow": "send-data",
    "input": {
      "room": "{{ params.room }}",
      "data": "{{ body.data }}",
      "topic": "{{ body.topic }}"
    }
  }
}
