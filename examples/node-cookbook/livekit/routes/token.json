{
  "id": "token",
  "method": "POST",
  "path": "/api/rooms/:room/token",
  "summary": "lk.token — issue a LiveKit access token for a room",
  "tags": ["livekit"],
  "trigger": {
    "workflow": "token",
    "input": {
      "room": "{{ params.room }}",
      "identity": "{{ body.identity }}",
      "name": "{{ body.name }}"
    }
  }
}
