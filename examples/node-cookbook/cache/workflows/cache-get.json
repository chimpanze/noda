{
  "id": "cache-get",
  "name": "Cache Get",
  "nodes": {
    "fetch": {
      "type": "cache.get",
      "services": { "cache": "app-cache" },
      "config": {
        "key": "{{ input.key }}"
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": { "value": "{{ nodes.fetch.value }}" }
      }
    },
    "not_found": {
      "type": "response.error",
      "config": {
        "status": 404,
        "code": "NOT_FOUND",
        "message": "Cache key not found"
      }
    }
  },
  "edges": [
    { "from": "fetch", "to": "respond" },
    { "from": "fetch", "output": "error", "to": "not_found" }
  ]
}
