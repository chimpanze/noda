{
  "id": "files-read",
  "name": "Read File",
  "nodes": {
    "load": {
      "type": "storage.read",
      "services": { "storage": "files" },
      "config": {
        "path": "{{ input.path }}"
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": { "content_base64": "{{ nodes.load.data }}", "content_type": "{{ nodes.load.content_type }}", "size": "{{ nodes.load.size }}" }
      }
    },
    "not_found": {
      "type": "response.error",
      "config": {
        "status": 404,
        "code": "NOT_FOUND",
        "message": "File not found"
      }
    }
  },
  "edges": [
    { "from": "load", "to": "respond" },
    { "from": "load", "output": "error", "to": "not_found" }
  ]
}
