{
  "id": "create-session",
  "name": "Create Session",
  "nodes": {
    "session": {
      "type": "auth.create_session",
      "services": { "auth": "auth", "database": "main-db" },
      "config": { "user_id": "{{ input.user_id }}", "ttl": "1h" }
    },
    "respond": {
      "type": "response.json",
      "config": { "status": 200, "body": "{{ nodes.session }}" }
    }
  },
  "edges": [
    { "from": "session", "output": "success", "to": "respond" }
  ]
}
