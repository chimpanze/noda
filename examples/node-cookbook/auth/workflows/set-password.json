{
  "id": "set-password",
  "name": "Set Password",
  "nodes": {
    "set": {
      "type": "auth.set_password",
      "services": { "auth": "auth", "database": "main-db" },
      "config": { "token": "{{ input.token }}", "password": "{{ input.password }}" }
    },
    "respond": {
      "type": "response.json",
      "config": { "status": 200, "body": { "updated": true } }
    },
    "rejected": {
      "type": "response.error",
      "config": { "status": 400, "code": "TOKEN_INVALID", "message": "reset token is unknown, expired, or already used" }
    }
  },
  "edges": [
    { "from": "set", "output": "success", "to": "respond" },
    { "from": "set", "output": "invalid", "to": "rejected" }
  ]
}
