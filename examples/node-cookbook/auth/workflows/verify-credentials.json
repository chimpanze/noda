{
  "id": "verify-credentials",
  "name": "Verify Credentials",
  "nodes": {
    "verify": {
      "type": "auth.verify_credentials",
      "services": { "auth": "auth", "database": "main-db" },
      "config": { "email": "{{ input.email }}", "password": "{{ input.password }}" }
    },
    "respond": {
      "type": "response.json",
      "config": { "status": 200, "body": "{{ nodes.verify }}" }
    },
    "rejected": {
      "type": "response.error",
      "config": { "status": 401, "code": "INVALID_CREDENTIALS", "message": "invalid email or password" }
    }
  },
  "edges": [
    { "from": "verify", "output": "success", "to": "respond" },
    { "from": "verify", "output": "invalid", "to": "rejected" }
  ]
}
