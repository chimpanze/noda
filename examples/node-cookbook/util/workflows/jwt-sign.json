{
  "id": "jwt-sign",
  "nodes": {
    "sign": { "type": "util.jwt_sign", "config": { "claims": { "sub": "{{ input.uid }}" }, "secret": "cookbook-demo-secret", "algorithm": "HS256", "expiry": "1h" } },
    "respond": { "type": "response.json", "config": { "status": 200, "body": { "token": "{{ nodes.sign }}" } } }
  },
  "edges": [ { "from": "sign", "to": "respond" } ]
}
