{
  "id": "auth-request-password-reset",
  "method": "POST",
  "path": "/auth/request-password-reset",
  "summary": "Request a password reset email",
  "tags": ["auth"],
  "middleware": ["limiter"],
  "body": {
    "schema": {
      "type": "object",
      "required": ["email"],
      "properties": {
        "email": { "type": "string" }
      }
    }
  },
  "trigger": {
    "workflow": "auth-request-password-reset",
    "input": { "email": "{{ body.email }}" }
  }
}
