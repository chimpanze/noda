{
  "services": {
    "main-db": {
      "plugin": "postgres",
      "config": {
        "url": "{{ $env('DATABASE_URL') }}"
      }
    }
  },
  "security": {
    "jwt": {
      "secret": "{{ $env('JWT_SECRET') }}",
      "algorithm": "HS256",
      "token_lookup": "header:Authorization"
    }
  },
  "middleware_presets": {
    "authenticated": ["auth.jwt"]
  }
}
