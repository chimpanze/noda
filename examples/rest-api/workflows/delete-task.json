{
  "id": "delete-task",
  "name": "Delete Task",
  "nodes": {
    "lookup": {
      "type": "db.query",
      "services": { "database": "main-db" },
      "config": {
        "query": "SELECT * FROM tasks WHERE id = $1 AND user_id = $2",
        "params": ["{{ input.task_id }}", "{{ input.user_id }}"]
      }
    },
    "check": {
      "type": "control.if",
      "config": {
        "condition": "{{ len(nodes.lookup) > 0 }}"
      }
    },
    "delete": {
      "type": "db.exec",
      "services": { "database": "main-db" },
      "config": {
        "query": "DELETE FROM tasks WHERE id = $1 AND user_id = $2",
        "params": ["{{ input.task_id }}", "{{ input.user_id }}"]
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 204
      }
    },
    "notfound": {
      "type": "response.error",
      "config": {
        "status": 404,
        "message": "Task not found"
      }
    }
  },
  "edges": [
    { "from": "lookup", "to": "check" },
    { "from": "check", "output": "then", "to": "delete" },
    { "from": "check", "output": "else", "to": "notfound" },
    { "from": "delete", "to": "respond" }
  ]
}
