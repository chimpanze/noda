{
  "id": "delete-task",
  "name": "Delete Task",
  "nodes": {
    "lookup": {
      "type": "db.findOne",
      "services": { "database": "main-db" },
      "config": {
        "table": "tasks",
        "where": { "id": "{{ input.task_id }}", "user_id": "{{ input.user_id }}" }
      }
    },
    "delete": {
      "type": "db.delete",
      "services": { "database": "main-db" },
      "config": {
        "table": "tasks",
        "where": { "id": "{{ input.task_id }}", "user_id": "{{ input.user_id }}" }
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 204
      }
    }
  },
  "edges": [
    { "from": "lookup", "to": "delete" },
    { "from": "delete", "to": "respond" }
  ]
}
