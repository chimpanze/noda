{
  "id": "create-task",
  "name": "Create Task",
  "nodes": {
    "validate": {
      "type": "transform.validate",
      "config": {
        "data": "{{ input }}",
        "schema": { "$ref": "schemas/CreateTask" }
      }
    },
    "insert": {
      "type": "db.create",
      "services": { "database": "main-db" },
      "config": {
        "table": "tasks",
        "data": {
          "title": "{{ input.title }}",
          "description": "{{ input.description }}",
          "user_id": "{{ input.user_id }}",
          "status": "todo"
        }
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 201,
        "body": "{{ nodes.insert }}"
      }
    }
  },
  "edges": [
    { "from": "validate", "to": "insert" },
    { "from": "insert", "to": "respond" }
  ]
}
