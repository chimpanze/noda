{
  "id": "get-task",
  "name": "Get Task",
  "nodes": {
    "fetch": {
      "type": "db.findOne",
      "services": { "database": "main-db" },
      "config": {
        "table": "tasks",
        "where": { "id": "{{ input.task_id }}", "user_id": "{{ input.user_id }}" }
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": "{{ nodes.fetch }}"
      }
    }
  },
  "edges": [
    { "from": "fetch", "to": "respond" }
  ]
}
