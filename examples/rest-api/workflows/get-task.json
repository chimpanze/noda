{
  "id": "get-task",
  "name": "Get Task",
  "nodes": {
    "fetch": {
      "type": "db.query",
      "services": { "database": "main-db" },
      "config": {
        "query": "SELECT * FROM tasks WHERE id = $1 AND user_id = $2",
        "params": ["{{ input.task_id }}", "{{ input.user_id }}"]
      }
    },
    "check": {
      "type": "control.if",
      "config": {
        "condition": "{{ len(nodes.fetch) > 0 }}"
      }
    },
    "found": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": "{{ nodes.fetch[0] }}"
      }
    },
    "notfound": {
      "type": "response.error",
      "config": {
        "status": 404,
        "message": "Task not found"
      }
    }
  },
  "edges": [
    { "from": "fetch", "to": "check" },
    { "from": "check", "output": "then", "to": "found" },
    { "from": "check", "output": "else", "to": "notfound" }
  ]
}
