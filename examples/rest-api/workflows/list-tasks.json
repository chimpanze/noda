{
  "id": "list-tasks",
  "name": "List Tasks",
  "nodes": {
    "total": {
      "type": "db.count",
      "services": { "database": "main-db" },
      "config": {
        "table": "tasks",
        "where": { "user_id": "{{ input.user_id }}" }
      }
    },
    "rows": {
      "type": "db.find",
      "services": { "database": "main-db" },
      "config": {
        "table": "tasks",
        "where": { "user_id": "{{ input.user_id }}" },
        "order": "created_at DESC",
        "limit": "{{ input.limit }}",
        "offset": "{{ (input.page - 1) * input.limit }}"
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": {
          "data": "{{ nodes.rows }}",
          "pagination": {
            "page": "{{ input.page }}",
            "limit": "{{ input.limit }}",
            "total": "{{ nodes.total.count }}"
          }
        }
      }
    }
  },
  "edges": [
    { "from": "total", "to": "respond" },
    { "from": "rows", "to": "respond" }
  ]
}
