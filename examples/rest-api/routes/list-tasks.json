{
  "id": "list-tasks",
  "method": "GET",
  "path": "/api/tasks",
  "summary": "List tasks with pagination",
  "tags": ["tasks"],
  "middleware": ["auth.jwt"],
  "trigger": {
    "workflow": "list-tasks",
    "input": {
      "page": "{{ query.page ?? '1' }}",
      "limit": "{{ query.limit ?? '20' }}",
      "user_id": "{{ auth.sub }}"
    }
  }
}
