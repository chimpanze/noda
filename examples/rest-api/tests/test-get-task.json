{
  "id": "test-get-task",
  "workflow": "get-task",
  "tests": [
    {
      "name": "task found",
      "input": {
        "task_id": "task-1",
        "user_id": "user-1"
      },
      "mocks": {
        "fetch": {
          "output": { "id": "task-1", "title": "My Task", "status": "todo" }
        },
        "respond": {
          "output": { "status": 200 }
        }
      },
      "expect": {
        "status": "success",
        "output": {
          "respond.status": 200
        }
      }
    },
    {
      "name": "task not found",
      "input": {
        "task_id": "nonexistent",
        "user_id": "user-1"
      },
      "mocks": {
        "fetch": {
          "error": { "message": "record not found" }
        }
      },
      "expect": {
        "status": "error"
      }
    }
  ]
}
