{
  "id": "get-document",
  "name": "Get Document",
  "nodes": {
    "fetch": {
      "type": "db.query",
      "services": { "database": "main-db" },
      "config": {
        "query": "SELECT id, title, content, owner_id, created_at, updated_at FROM documents WHERE id = $1 LIMIT 1",
        "params": ["{{ input.doc_id }}"]
      }
    },
    "check": {
      "type": "control.if",
      "config": {
        "condition": "{{ len(nodes.fetch) > 0 }}"
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": "{{ nodes.fetch[0] }}"
      }
    },
    "not_found": {
      "type": "response.error",
      "config": {
        "status": 404,
        "code": "NOT_FOUND",
        "message": "Document not found"
      }
    }
  },
  "edges": [
    { "from": "fetch", "to": "check" },
    { "from": "check", "output": "then", "to": "respond" },
    { "from": "check", "output": "else", "to": "not_found" }
  ]
}
