{
  "id": "get-document",
  "name": "Get Document",
  "nodes": {
    "fetch": {
      "type": "db.findOne",
      "services": { "database": "main-db" },
      "config": {
        "table": "documents",
        "select": ["id", "title", "content", "owner_id", "created_at", "updated_at"],
        "where": { "id": "{{ input.doc_id }}" }
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": "{{ nodes.fetch }}"
      }
    }
  },
  "edges": [
    { "from": "fetch", "to": "respond" }
  ]
}
