{
  "id": "list-documents",
  "name": "List Documents",
  "nodes": {
    "fetch": {
      "type": "db.find",
      "services": { "database": "main-db" },
      "config": {
        "table": "documents",
        "select": ["id", "title", "content", "owner_id", "created_at", "updated_at"],
        "where": { "owner_id": "{{ input.owner_id }}" },
        "order": "created_at DESC"
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": "{{ nodes.fetch }}"
      }
    }
  },
  "edges": [
    { "from": "fetch", "to": "respond" }
  ]
}
