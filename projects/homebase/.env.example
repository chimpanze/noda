# --- required on the server ---
SETUP_TOKEN=change-me-to-a-long-random-string
PUBLIC_BASE_URL=https://your.domain
# domain Caddy serves (docker-compose.edge.yml override only; required there at parse time)
DOMAIN=your.domain
# LiveKit Cloud credentials (https://cloud.livekit.io → project → Keys)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# --- optional ---
# Pin the noda image tag pulled from ghcr.io/chimpanze/noda (defaults to 0.0.5).
# Use a slim semver tag (0.0.5, 0.0, 0) or `main` for latest off main.
NODA_VERSION=0.0.5
# Max request body size in bytes (default 1 GiB). Also required when running
# noda outside docker (compose's ${BODY_LIMIT:-...} default doesn't apply
# there, so a missing value is a hard config error).
BODY_LIMIT=1073741824
# Uncomment on the production host so noda loads noda.production.json
# (enables trust_proxy so rate limiting sees real client IPs behind Caddy)
# NODA_ENV=production

# --- only needed when running noda outside docker ---
DATABASE_URL=postgres://noda:noda@localhost:5432/noda?sslmode=disable
FILES_PATH=./data/files
