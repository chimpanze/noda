{
  "id": "drop-update",
  "method": "PATCH",
  "path": "/drops/:id",
  "summary": "Replace a drop's text",
  "tags": ["drops"],
  "middleware": ["auth.session"],
  "body": {
    "schema": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": { "type": "string", "minLength": 1 }
      }
    }
  },
  "trigger": {
    "workflow": "drop-update",
    "input": { "id": "{{ params.id }}", "text": "{{ body.text }}" }
  }
}
