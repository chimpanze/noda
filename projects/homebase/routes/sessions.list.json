{
  "id": "sessions-list",
  "method": "GET",
  "path": "/auth/sessions",
  "summary": "List active sessions (devices)",
  "tags": ["auth"],
  "middleware": ["auth.session"],
  "trigger": {
    "workflow": "sessions-list",
    "input": { "user_id": "{{ auth.sub }}", "session_id": "{{ auth.claims.session_id }}" }
  }
}
