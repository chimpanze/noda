{
  "id": "drop-upload",
  "method": "POST",
  "path": "/drops/upload",
  "summary": "Upload a file drop (multipart; optional text comment)",
  "tags": ["drops"],
  "middleware": ["auth.session"],
  "trigger": {
    "workflow": "drop-upload",
    "files": ["file"],
    "input": { "file": "file", "text": "{{ (body ?? {}).text ?? '' }}" }
  }
}
