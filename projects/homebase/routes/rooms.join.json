{
  "id": "room-join",
  "method": "GET",
  "path": "/j/:token",
  "summary": "Join a room via guest link (no auth)",
  "tags": ["public"],
  "middleware": ["limiter", "security.headers"],
  "trigger": {
    "workflow": "room-join",
    "input": {
      "token": "{{ params.token }}",
      "name": "{{ query.name ?? '' }}"
    }
  }
}
