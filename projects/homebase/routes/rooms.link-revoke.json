{
  "id": "room-link-revoke",
  "method": "DELETE",
  "path": "/rooms/:name/link",
  "summary": "Revoke the room's guest link (room stays up)",
  "tags": ["rooms"],
  "middleware": ["auth.session"],
  "trigger": {
    "workflow": "room-link-revoke",
    "input": { "name": "{{ params.name }}" }
  }
}
