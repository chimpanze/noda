{
  "id": "drop-create",
  "name": "Drops: Create text drop",
  "nodes": {
    "insert": {
      "type": "db.create",
      "services": { "database": "main-db" },
      "config": {
        "table": "drops",
        "data": {
          "id": "{{ $uuid() }}",
          "text": "{{ input.text }}"
        }
      }
    },
    "respond": {
      "type": "response.json",
      "config": { "status": 201, "body": "{{ nodes.insert }}" }
    }
  },
  "edges": [
    { "from": "insert", "to": "respond" }
  ]
}
