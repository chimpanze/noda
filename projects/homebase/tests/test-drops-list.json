{
  "id": "test-drops-list",
  "workflow": "drops-list",
  "tests": [
    {
      "name": "lists drops newest first with cursor",
      "input": { "q": "", "before": "" },
      "mocks": {
        "find": { "output": [ { "id": "d2", "text": "newer", "created_at": "2026-07-07T11:00:00Z" }, { "id": "d1", "text": "older", "created_at": "2026-07-07T10:00:00Z" } ] },
        "respond": { "output": { "status": 200 } }
      },
      "expect": { "status": "success", "output": { "respond.status": 200 } }
    },
    {
      "name": "empty result gives null cursor",
      "input": { "q": "zzz", "before": "" },
      "mocks": {
        "find": { "output": [] },
        "respond": { "output": { "status": 200 } }
      },
      "expect": { "status": "success", "output": { "respond.status": 200 } }
    },
    {
      "name": "malformed before cursor gets 400",
      "input": { "q": "", "before": "garbage", "before_id": "" },
      "mocks": {
        "find": { "output": [] },
        "respond_bad_cursor": { "output": { "status": 400 } }
      },
      "expect": { "status": "success", "output": { "respond_bad_cursor.status": 400 } }
    },
    {
      "name": "RFC3339Nano cursor is accepted",
      "input": { "q": "", "before": "2026-07-12T10:00:00.123456Z", "before_id": "abc" },
      "mocks": {
        "find": { "output": [] },
        "respond": { "output": { "status": 200 } }
      },
      "expect": { "status": "success", "output": { "respond.status": 200 } }
    },
    {
      "name": "Postgres text-form cursor is accepted",
      "input": { "q": "", "before": "2026-07-12 10:00:00.123456+00", "before_id": "" },
      "mocks": {
        "find": { "output": [] },
        "respond": { "output": { "status": 200 } }
      },
      "expect": { "status": "success", "output": { "respond.status": 200 } }
    }
  ]
}
