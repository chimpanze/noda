{
  "id": "stream-status",
  "name": "Stream Status",
  "nodes": {
    "get_cache": {
      "type": "cache.get",
      "services": { "cache": "app-cache" },
      "config": {
        "key": "stream:info"
      }
    },
    "check_live": {
      "type": "control.if",
      "config": {
        "condition": "{{ nodes.get_cache.value != nil }}"
      }
    },
    "respond_live": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": {
          "live": true,
          "title": "{{ nodes.get_cache.value.title }}",
          "description": "{{ nodes.get_cache.value.description }}",
          "started_at": "{{ nodes.get_cache.value.started_at }}"
        }
      }
    },
    "respond_offline": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": {
          "live": false
        }
      }
    }
  },
  "edges": [
    { "from": "get_cache", "output": "success", "to": "check_live" },
    { "from": "get_cache", "output": "error", "to": "respond_offline" },
    { "from": "check_live", "output": "then", "to": "respond_live" },
    { "from": "check_live", "output": "else", "to": "respond_offline" }
  ]
}
