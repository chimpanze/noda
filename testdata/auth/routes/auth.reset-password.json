{
  "id": "auth-reset-password",
  "method": "POST",
  "path": "/auth/reset-password",
  "summary": "Reset a password using a one-time token",
  "tags": ["auth"],
  "middleware": ["limiter"],
  "body": {
    "schema": {
      "type": "object",
      "required": ["token", "password"],
      "properties": {
        "token": { "type": "string" },
        "password": { "type": "string", "minLength": 8, "maxLength": 512 }
      }
    }
  },
  "trigger": {
    "workflow": "auth-reset-password",
    "input": { "token": "{{ body.token }}", "password": "{{ body.password }}" }
  }
}
