{
  "id": "on-livekit-event",
  "name": "On LiveKit Event",
  "nodes": {
    "log-event": {
      "type": "util.log",
      "config": {
        "level": "info",
        "message": "LiveKit event received",
        "fields": {
          "event": "{{ input.event }}"
        }
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": {
          "received": true
        }
      }
    }
  },
  "edges": [
    { "from": "log-event", "to": "respond" }
  ]
}
