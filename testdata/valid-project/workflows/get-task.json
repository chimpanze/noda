{
  "id": "get-task",
  "name": "Get Task",
  "nodes": {
    "fetch": {
      "type": "db.findOne",
      "services": { "database": "main-db" },
      "config": {
        "table": "tasks",
        "where": { "id": "{{ input.task_id }}" }
      }
    },
    "check": {
      "type": "control.if",
      "config": {
        "condition": "{{ nodes.fetch != null }}"
      }
    },
    "respond-ok": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": "{{ nodes.fetch }}"
      }
    },
    "respond-not-found": {
      "type": "response.error",
      "config": {
        "status": 404,
        "message": "Task not found"
      }
    }
  },
  "edges": [
    { "from": "fetch", "to": "check" },
    { "from": "check", "output": "true", "to": "respond-ok" },
    { "from": "check", "output": "false", "to": "respond-not-found" }
  ]
}
