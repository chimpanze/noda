{
  "id": "list-tasks",
  "name": "List Tasks",
  "nodes": {
    "query": {
      "type": "db.find",
      "services": { "database": "main-db" },
      "config": {
        "table": "tasks",
        "limit": "{{ input.per_page }}",
        "offset": "{{ (input.page - 1) * input.per_page }}"
      }
    },
    "count": {
      "type": "db.count",
      "services": { "database": "read-db" },
      "config": {
        "table": "tasks"
      }
    },
    "respond": {
      "type": "response.json",
      "config": {
        "status": 200,
        "body": {
          "items": "{{ nodes.query }}",
          "total": "{{ nodes.count.count }}"
        }
      }
    }
  },
  "edges": [
    { "from": "query", "to": "respond" },
    { "from": "count", "to": "respond" }
  ]
}
