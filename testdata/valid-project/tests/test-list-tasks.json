{
  "id": "test-list-tasks",
  "workflow": "list-tasks",
  "tests": [
    {
      "name": "lists tasks with results",
      "input": {
        "page": 1,
        "per_page": 10
      },
      "mocks": {
        "query": {
          "output": [
            {"id": "1", "title": "Task 1", "status": "todo"},
            {"id": "2", "title": "Task 2", "status": "done"}
          ]
        },
        "count": {
          "output": 2
        },
        "respond": {
          "output": {"status": 200}
        }
      },
      "expect": {
        "status": "success",
        "output": {
          "respond.status": 200
        }
      }
    },
    {
      "name": "empty task list",
      "input": {
        "page": 1,
        "per_page": 10
      },
      "mocks": {
        "query": { "output": [] },
        "count": { "output": 0 },
        "respond": { "output": {"status": 200} }
      },
      "expect": {
        "status": "success"
      }
    }
  ]
}
