{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "method": {
      "type": "string",
      "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
    },
    "path": { "type": "string" },
    "summary": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "middleware": {
      "type": "array",
      "items": { "type": "string" }
    },
    "middleware_preset": { "type": "string" },
    "params": {
      "type": "object",
      "properties": {
        "schema": { "type": "object" }
      }
    },
    "query": {
      "type": "object",
      "properties": {
        "schema": { "type": "object" }
      }
    },
    "body": {
      "type": "object",
      "properties": {
        "schema": {
          "type": "object",
          "description": "Inline JSON Schema or {\"$ref\": \"schemas/<Name>\"} — <Name> is a top-level key in a schemas/*.json definitions file, or the filename of a bare-schema file. See docs/02-config/schemas.md."
        },
        "content_type": { "type": "string" },
        "validate": { "type": "boolean" }
      }
    },
    "trigger": {
      "type": "object",
      "properties": {
        "workflow": { "type": "string" },
        "input": { "type": "object" },
        "files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "raw_body": { "type": "boolean" },
        "coerce": {
          "type": "boolean",
          "description": "Numeric coercion of trigger inputs sourced from string-typed transports (params/query/headers/form body). Default true."
        }
      },
      "required": ["workflow"]
    },
    "response_timeout": { "type": "string" },
    "response": {
      "type": "object",
      "properties": {
        "validate": {
          "oneOf": [
            { "type": "string", "enum": ["warn", "strict"] },
            { "type": "boolean" }
          ]
        }
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "schema": { "type": "object" }
        }
      }
    }
  },
  "required": ["id", "method", "path", "trigger"]
}
