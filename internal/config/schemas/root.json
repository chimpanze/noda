{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "services": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "plugin": { "type": "string" },
          "config": { "type": "object" }
        },
        "required": ["plugin"]
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "jwt": {
          "type": "object",
          "properties": {
            "secret": { "type": "string" },
            "algorithm": { "type": "string" },
            "token_lookup": { "type": "string" }
          }
        },
        "casbin": {
          "type": "object",
          "description": "Casbin policy-based access control for casbin.enforce middleware. The subject is the authenticated user id (auth.sub); use role_links to map users to roles.",
          "properties": {
            "model": {
              "type": "string",
              "description": "Inline Casbin model text (detected when it contains '[request_definition]') or a path to a .conf file"
            },
            "policies": {
              "type": "array",
              "description": "Policy rule tuples, e.g. [\"p\", \"admin\", \"/api/*\", \"GET\"] (first element is the policy type, usually \"p\")",
              "items": { "type": "array" }
            },
            "role_links": {
              "type": "array",
              "description": "Role assignment tuples, e.g. [\"g\", \"alice\", \"admin\"] (first element is the grouping type, usually \"g\")",
              "items": { "type": "array" }
            },
            "tenant_param": {
              "type": "string",
              "description": "URL or query parameter carrying the tenant id, for multi-tenant (domain) RBAC"
            }
          },
          "required": ["model"]
        }
      }
    },
    "middleware_presets": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "middleware_instances": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "config": { "type": "object" }
        },
        "required": ["type", "config"]
      }
    },
    "route_groups": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "middleware_preset": { "type": "string" },
          "middleware": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "server": {
      "type": "object",
      "properties": {
        "port": {
          "oneOf": [
            { "type": "integer", "minimum": 1, "maximum": 65535 },
            { "type": "string" }
          ]
        },
        "read_timeout": { "type": "string" },
        "write_timeout": { "type": "string" },
        "body_limit": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string" }
          ]
        },
        "response_timeout": { "type": "string" },
        "shutdown_deadline": { "type": "string" },
        "health_timeout": { "type": "string" },
        "expression_memory_budget": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string" }
          ]
        },
        "expression_strict_mode": { "type": "boolean" },
        "trust_proxy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "proxies": { "type": "array", "items": { "type": "string" } },
            "loopback": { "type": "boolean" },
            "link_local": { "type": "boolean" },
            "private": { "type": "boolean" },
            "header": { "type": "string" }
          }
        },
        "openapi": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "docs": { "type": "boolean" },
            "path": { "type": "string" },
            "docs_path": { "type": "string" }
          }
        }
      }
    },
    "global_middleware": {
      "type": "array",
      "items": { "type": "string" }
    },
    "wasm_runtimes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "module": { "type": "string" },
          "tick_rate": { "type": "integer" },
          "encoding": { "type": "string", "enum": ["json", "msgpack"] },
          "services": {
            "type": "array",
            "items": { "type": "string" }
          },
          "connections": {
            "type": "array",
            "items": { "type": "string" }
          },
          "allowed_workflows": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Workflow IDs this module is allowed to trigger. Empty list denies all."
          },
          "allow_outbound": {
            "type": "object",
            "properties": {
              "http": { "type": "array", "items": { "type": "string" } },
              "ws": { "type": "array", "items": { "type": "string" } }
            }
          },
          "config": { "type": "object" },
          "tick_timeout": { "type": "string", "description": "Max duration for a single tick call (e.g. '5s', '500ms'). Default: 10x tick budget." }
        },
        "required": ["module"]
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "providers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["dotenv", "env"] },
              "config": { "type": "object" }
            },
            "required": ["type"]
          }
        }
      }
    }
  }
}
