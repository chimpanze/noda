{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "sync": {
      "type": "object",
      "properties": {
        "pubsub": { "type": "string" }
      },
      "required": ["pubsub"]
    },
    "endpoints": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["websocket", "sse"] },
          "path": { "type": "string" },
          "middleware": { "type": "array", "items": { "type": "string" } },
          "middleware_preset": { "type": "string" },
          "channels": {
            "type": "object",
            "properties": {
              "pattern": { "type": "string" },
              "max_per_channel": { "type": "integer" }
            }
          },
          "ping_interval": { "type": "string" },
          "max_message_size": { "type": "string" },
          "retry": { "type": "string" },
          "heartbeat": { "type": "string" },
          "on_connect": { "type": "string" },
          "on_message": { "type": "string" },
          "on_disconnect": { "type": "string" }
        },
        "required": ["type", "path"]
      }
    }
  },
  "required": ["sync"]
}
