{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "nodes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "services": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "as": { "type": "string" },
          "position": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          },
          "config": {
            "type": "object",
            "description": "Node-specific config. Not validated here — each node type validates its own config via NodeDescriptor.ConfigSchema() at bootstrap time."
          }
        },
        "required": ["type"]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": { "type": "string" },
          "output": { "type": "string" },
          "to": { "type": "string" },
          "retry": {
            "type": "object",
            "properties": {
              "attempts": { "type": "integer" },
              "backoff": { "type": "string", "enum": ["fixed", "exponential"] },
              "delay": { "type": "string" }
            }
          }
        },
        "required": ["from", "to"]
      }
    }
  },
  "required": ["id", "nodes", "edges"]
}
